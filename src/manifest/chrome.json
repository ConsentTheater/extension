{
  "manifest_version": 3,
  "name": "ConsentTheater",
  "description": "See what a website is really tracking before you click Accept — in plain language, no tech skills required.",
  "version": "0.2.0",
  "action": {
    "default_title": "ConsentTheater",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "ui/sidebar.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "webRequest",
    "webNavigation",
    "browsingData",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
