{
  "name": "@consenttheater/extension",
  "version": "0.1.0",
  "description": "See what a website is really doing before you click Accept. ConsentTheater spots tracking cookies, hidden data leaks, and sneaky consent banners — in plain language, no tech skills required.",
  "author": {
    "name": "ConsentTheater",
    "email": "developer@consenttheater.org",
    "url": "https://consenttheater.org"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ConsentTheater/extension.git"
  },
  "homepage": "https://consenttheater.org",
  "bugs": {
    "url": "https://github.com/ConsentTheater/extension/issues"
  },
  "keywords": [
    "gdpr",
    "privacy",
    "cookies",
    "consent",
    "cookie-checker",
    "tracker-blocker",
    "compliance",
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "tracker-detection"
  ],
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:chrome": "node scripts/build.js --target=chrome",
    "build:firefox": "node scripts/build.js --target=firefox",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "zip": "node scripts/zip.js",
    "zip:chrome": "node scripts/zip.js --target=chrome",
    "zip:firefox": "node scripts/zip.js --target=firefox",
    "zip:all": "npm run zip:chrome && npm run zip:firefox",
    "dev": "node scripts/build.js --watch",
    "dev:chrome": "node scripts/build.js --target=chrome --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "validate:chrome": "npm run build:chrome && node scripts/validate-chrome.js",
    "validate:firefox": "npm run build:firefox && addons-linter dist/firefox/",
    "validate": "npm run lint && npm run test && npm run validate:chrome && npm run validate:firefox",
    "release": "npm run clean && npm run validate && npm run build:all && npm run zip:all"
  },
  "devDependencies": {
    "@consenttheater/playbill": "^0.1.2",
    "@phosphor-icons/react": "^2.1.10",
    "@preact/preset-vite": "^2.10.5",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.5",
    "addons-linter": "^10.3.0",
    "archiver": "^7.0.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-security": "^4.0.0",
    "fs-extra": "^11.3.4",
    "postcss": "^8.5.10",
    "preact": "^10.29.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
